# GridSense — environment variables (dev prototype credentials)
# These are the values docker-compose.yml substitutes for ${...}.
# Dev-only passwords; this file is what the B.1 rule means by
# "all passwords supplied via a .env file".

NEO4J_PASSWORD=gridsense_dev
MONGO_USER=gridsense
MONGO_PASSWORD=gridsense_dev
POSTGRES_USER=gridsense
POSTGRES_PASSWORD=gridsense_dev
POSTGRES_DB=gridsense
REDIS_PASSWORD=gridsense_dev
